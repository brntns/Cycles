# Copy to .env for local tooling that reads it, or export these directly.
# docker-compose.yml already provides sane defaults for local dev and only
# needs CYCLE_PASSWORD.

# Postgres connection string. docker-compose sets this for you; only needed
# here if you're running the server outside of docker compose.
DATABASE_URL=postgres://cycles:cycles@localhost:5432/cycles?sslmode=disable

# The single-user login password. Required, no default.
CYCLE_PASSWORD=changeme

# Set to "false" for local HTTP development so the session cookie isn't
# marked Secure (browsers drop Secure cookies on non-HTTPS origins).
# Leave unset (defaults to true) in every real deployment.
COOKIE_SECURE=false

# Railway provides PORT automatically. Falls back to 4715 locally.
PORT=4715
